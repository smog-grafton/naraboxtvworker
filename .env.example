APP_NAME="NaraboxTV Worker"
APP_ENV=production
APP_KEY=wwwogwgw80cwo4g4skw8oggg
APP_DEBUG=false
APP_URL=https://worker.naraboxtv.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# In Coolify: use the MySQL internal URL host (between @ and :3306), not 127.0.0.1.
# If your MySQL URL has ?ssl-mode=REQUIRED, set DB_SSL_MODE=REQUIRED below.
DB_CONNECTION=mysql
DB_HOST=f08kgck0g8sk8kkkckwg8kkk
DB_PORT=3306
DB_DATABASE=default
DB_USERNAME=naraboxtvuserserver
DB_PASSWORD=your_mysql_password_from_coolify_internal_url
# Required when MySQL has require_secure_transport=ON (e.g. Coolify managed MySQL).
DB_SSL_MODE=REQUIRED

QUEUE_CONNECTION=redis
CACHE_STORE=redis
# Use redis for session when Redis is reachable. If / or /admin return 500, try SESSION_DRIVER=file (queues still use Redis).
SESSION_DRIVER=redis

# In Coolify: set REDIS_HOST to your Redis service name (e.g. redis), NOT 127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

CDN_API_BASE_URL=https://cdn.naraboxtv.com
CDN_API_TOKEN=your_cdn_api_bearer_token_here
# Callback timeout (default 90s); increase if CDN is slow to respond (e.g. behind proxy)
CDN_CALLBACK_TIMEOUT=90
CDN_CALLBACK_CONNECT_TIMEOUT=15

PORTAL_API_BASE_URL=https://portal.naraboxtv.com
PORTAL_API_TOKEN=your_portal_api_bearer_token_here

WORKER_TEMP_DIR=/tmp/narabox-worker
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

TRANSCODE_QUEUE=transcode
PROBE_QUEUE=probe
SYNC_QUEUE=sync

HORIZON_PREFIX=narabox_worker_horizon:
# Transcode jobs can take 15–60+ min per long video; use 4+ to process multiple in parallel
HORIZON_TRANSCODE_PROCESSES=2
HORIZON_TRANSCODE_TIMEOUT=7200
HORIZON_PROBE_PROCESSES=4
HORIZON_SYNC_PROCESSES=2

# Bearer token for CDN/Portal to call this worker API (submit job, status, retry)
WORKER_API_TOKEN=your_worker_api_bearer_token_here
